# Khipu Finance — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# In standalone mode (open app.html directly) keys are entered via the ⚙ settings
# panel and stored only in the browser (localStorage) — no .env needed.

# ── Core ────────────────────────────────────────────────────────
# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret

# ── Market Data ─────────────────────────────────────────────────
# Finnhub (free tier OK for development): https://finnhub.io/register
FINNHUB_KEY=your_finnhub_api_key_here

# Financial Modeling Prep (fundamentals, price targets): https://financialmodelingprep.com/developer
FMP_KEY=your_fmp_key_here

# Marketstack (EOD prices): https://marketstack.com
MARKETSTACK_KEY=your_marketstack_key_here

# Alpha Vantage (free tier, needed for VaR/CVaR): https://www.alphavantage.co/support/#api-key
AV_KEY=your_alpha_vantage_key_here

# ── AI / Claude ─────────────────────────────────────────────────
# Anthropic API key: https://console.anthropic.com/
ANTHROPIC_KEY=sk-ant-...

# ── Bixby Voice (ElevenLabs) ────────────────────────────────────
# ElevenLabs API key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_KEY=your_elevenlabs_key_here
# ElevenLabs Conversational AI agent ID (create at elevenlabs.io/app/conversational-ai)
ELEVENLABS_AGENT_ID=your_agent_id_here

# ── RAG / Second Brain Microservice ─────────────────────────────
# URL where the RAG server is running (docker-compose sets this automatically)
RAG_URL=http://localhost:5051

# ── MiroFish Simulation ─────────────────────────────────────────
# URL where MiroFish (or LiteLLM proxy) is running
# With docker-compose this is handled automatically via service names
MIROFISH_URL=http://localhost:4000

# LiteLLM proxy master key (authenticates requests to the LiteLLM proxy)
LITELLM_MASTER_KEY=khipu-litellm-key

# ── OpenAI (optional) ───────────────────────────────────────────
# Only needed if MiroFish must call OpenAI directly.
# When using the LiteLLM proxy, set to a placeholder — Claude handles it.
OPENAI_KEY=sk-placeholder

# ── Flask Config ────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000
